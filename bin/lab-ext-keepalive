#!/usr/bin/env bash
# lab-ext-keepalive-keepalive — ensure the external agent daemon is up. Idempotent: it starts the
# daemon ONLY if it isn't already running (the daemon's own single-instance lock guarantees
# no double-run). Driven by cron (@reboot + every few minutes) so the daemon survives crashes
# and node reboots. Safe to run by hand anytime. Cheap: just checks a lock + /proc.
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export HOME="${HOME:-$HOME}"
export PATH="${LAB_NODE_BIN:+$LAB_NODE_BIN:}$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"
LAB_HOME="${LAB_HOME:-$HOME/lab}"
# Site config: per-install overrides (paths, model, node bin). Never committed —
# the repo ships generic defaults; your deployment sets reality here.
# A syntax error here must not brick every command, so validate before sourcing.
if [ -f "$LAB_HOME/lab.env" ]; then
  if bash -n "$LAB_HOME/lab.env" 2>/dev/null; then set -a; . "$LAB_HOME/lab.env"; set +a
  else echo "lab: WARNING — $LAB_HOME/lab.env has a syntax error and was IGNORED (values with spaces need quotes). Check: bash -n $LAB_HOME/lab.env" >&2; fi
fi

KLOG="${LAB_CODEX_WORK:-$LAB_HOME/.work/${LAB_EXT_AGENT:-codex}}/keepalive.log"
mkdir -p "$(dirname "$KLOG")" 2>/dev/null || true

# `lab ext codex start` is a no-op when already running, or (re)launches it detached.
out="$("$SELF/lab" ext "${LAB_EXT_AGENT:-codex}" start 2>&1)" || true

# Stay quiet on the healthy path; log only real (re)starts and failures.
case "$out" in
  *"already running"*) : ;;
  *) printf '%s  %s\n' "$(date '+%F %T')" "$(printf '%s' "$out" | tr '\n' ' ')" >> "$KLOG" 2>/dev/null || true ;;
esac
