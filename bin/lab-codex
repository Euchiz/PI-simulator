#!/usr/bin/env bash
# lab-codex — run OpenAI's Codex CLI as a LIVE lab "session" named `codex`.
#
# It behaves like any other lab session: holds a watcher lock (so `lab who` shows
# it LIVE), watches its own inbox, answers each incoming message by running
# `codex exec` LOCALLY against the RNA project, and posts the reply back to the
# sender as `codex`. Other agents just do:
#     ~/lab/bin/lab send codex "subject" "body"
# and an independent review lands in their inbox a little later.
#
# SECURITY MODEL: the default sandbox is read-only with -a never, so codex can inspect the
# project and run bounded read-only shell commands, but any write/move/delete or job start
# FAILS instead of waiting for approval. read-only is the real enforcement boundary; the
# reviewer preamble is a second layer. Only set LAB_CODEX_SANDBOX=workspace-write (or,
# deliberately, danger-full-access) if you trust every sender and every message.
#
# Start it (foreground, or under tmux/nohup so it outlives one Claude session):
#     ~/lab/bin/lab-codex
# Stop it:
#     kill "$(cut -d' ' -f1 ~/lab/.watch/codex.lock)"      # or Ctrl-C in the foreground
#
# Env knobs:
#   LAB_CODEX_INTERVAL   inbox poll seconds                      (default 30)
#   LAB_CODEX_CD         codex working root                      (default: $PWD)
#   LAB_CODEX_SANDBOX    read-only | workspace-write | danger-full-access (default read-only)
#   LAB_CODEX_MODEL      model                                   (default gpt-5.6-sol)
#   LAB_CODEX_REASONING  model_reasoning_effort                  (default xhigh)
#   LAB_CODEX_TIMEOUT    per-message wall-clock cap, seconds     (default 900)
#   LAB_CODEX_BACKOFF    sleep after a quota/rate-limit hit, s   (default 900)
#   LAB_CODEX_BIN        path to the codex binary                (default: nvm install)
#
# THREADING: the message SUBJECT is a conversation key. The first message with a given subject
# starts a codex session; any later message (from ANY agent) with the same subject RESUMES it, so
# codex keeps context and agents needn't resend it. A new subject = a new session. Sessions persist
# in $CODEX_HOME (default ~/.codex, inspect via `codex resume`); the subject->session map lives in
# ~/lab/.watch/codex.threads.
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
LAB="$LAB_HOME/bin/lab"
KEY="codex"
INBOX="$LAB_HOME/inbox/$KEY"
LOCKDIR="$LAB_HOME/.watch"
LOCK="$LOCKDIR/$KEY.lock"
EXT="$LAB_HOME/external.tsv"

INTERVAL="${LAB_CODEX_INTERVAL:-30}"
PROJECT="${LAB_CODEX_CD:-$PWD}"
SANDBOX="${LAB_CODEX_SANDBOX:-read-only}"
MODEL="${LAB_CODEX_MODEL:-gpt-5.6-sol}"
REASONING="${LAB_CODEX_REASONING:-xhigh}"
TIMEOUT="${LAB_CODEX_TIMEOUT:-900}"
BACKOFF="${LAB_CODEX_BACKOFF:-900}"
CODEX_BIN="${LAB_CODEX_BIN:-$HOME/.nvm/versions/node/v24.15.0/bin/codex}"
WORK="${LAB_CODEX_WORK:-$LAB_HOME/.work/codex}"      # prompts + outputs on scratch, never /home
export CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"     # sessions persist here — inspect via `codex resume`
THREADS="$LOCKDIR/codex.threads"                    # subject-key -> session-uuid map (conversation memory)

# Always authenticate via the stored ChatGPT account, never a stray API key in the env.
unset OPENAI_API_KEY 2>/dev/null || true

export PATH="$HOME/.nvm/versions/node/v24.15.0/bin:$PATH"
[ -x "$CODEX_BIN" ] || CODEX_BIN="$(command -v codex || true)"
[ -n "$CODEX_BIN" ] && [ -x "$CODEX_BIN" ] || { echo "lab-codex: codex binary not found (set LAB_CODEX_BIN)" >&2; exit 1; }

mkdir -p "$INBOX/.read" "$INBOX/.failed" "$INBOX/.rejected" "$LOCKDIR" "$WORK"

# register `codex` as an external reviewer (idempotent)
TAB="$(printf '\t')"
touch "$EXT"
grep -q "^codex${TAB}" "$EXT" 2>/dev/null \
  || printf 'codex\tcodex\texternal\tChatGPT/Codex external reviewer (local, agentic)\n' >> "$EXT"

# single-instance guard: take over only a DEAD lock, never a live one
if [ -f "$LOCK" ]; then
  old_pid="$(cut -d' ' -f1 "$LOCK" 2>/dev/null || true)"
  if [ -n "${old_pid:-}" ] && [ "$old_pid" != "$$" ] && kill -0 "$old_pid" 2>/dev/null \
     && tr '\0' ' ' < "/proc/$old_pid/cmdline" 2>/dev/null | grep -q 'lab-codex'; then
    echo "lab-codex: already running (pid $old_pid) — exiting." >&2; exit 0
  fi
  # else: stale lock (dead pid, or pid reused by an unrelated process) — take over
fi
printf '%s %s\n' "$$" "codex-daemon" > "$LOCK"
cleanup() { [ -n "${SLEEP_PID:-}" ] && kill "$SLEEP_PID" 2>/dev/null; rm -f "$LOCK" 2>/dev/null || true; }
trap cleanup EXIT
trap 'cleanup; exit 143' TERM
trap 'cleanup; exit 130' INT

echo "[lab-codex] LIVE as '$KEY' (pid $$) — polling $INBOX every ${INTERVAL}s"
echo "[lab-codex]   codex=$CODEX_BIN  model=$MODEL  reasoning=$REASONING"
echo "[lab-codex]   cd=$PROJECT  sandbox=$SANDBOX  timeout=${TIMEOUT}s"
echo "[lab-codex]   threaded by subject; sessions persist in $CODEX_HOME (map: $THREADS)"
[ "$SANDBOX" = "danger-full-access" ] && echo "[lab-codex]   WARNING: full account access, no approvals — every inbox sender is trusted."

# Prepended to every request: identity + hard limits for this shared node + data-safety.
read -r -d '' HOUSE <<'EOF' || true
You are "codex" — an EXTERNAL, independent peer reviewer in a multi-agent research lab that
studies RNA modification and structure from nanopore (ONT) direct-RNA data. The other agents are
Claude sessions; they message you for a skeptical second opinion, a code/method review, or an
independent check of a claim. Be rigorous, concrete, and brief. Prefer verifying against the
actual files/data in your working directory over speculation, and say plainly when something is
wrong, unsupported, or a likely artifact.

Review only. You may run bounded, read-only inspection commands to verify claims against the
actual files and data in your working directory. Do NOT create, modify, move, or delete files,
start jobs, or perform external mutations — the sandbox will make such attempts fail. If a useful
check would require writing files, report that limitation in your reply instead of working around
it. Lab hard rule, independent of the sandbox: never delete, overwrite, or relocate any dataset
or result without explicit human (Zac) approval.

HARD ENVIRONMENT RULES — this runs on a SHARED 4-core HPC login node over NFS:
- NEVER run broad filesystem scans (find/du/ls -R/grep -r/rg) rooted at /, /home, /mnt, or any
  mount root. Scope every command to the narrowest subdirectory. A single wide find has taken
  this node down for all users before. Do not do it.
- Keep shell commands cheap and bounded; you are one guest among several live agents.
- Any file larger than ~100 MB must go under your scratch dir, never under /home.

Your FINAL message is delivered verbatim to the requester, so make it the answer itself
(findings + reasoning), not a meta-summary of what you did.
EOF

# --- conversation threading: the message SUBJECT is the session key ---
thread_key() {   # normalize a subject to a stable key (strip leading re:, lowercase, dash-collapse)
  printf '%s' "$1" \
   | sed -E 's/^([[:space:]]*[Rr][Ee]:[[:space:]]*)+//' \
   | tr '[:upper:]' '[:lower:]' \
   | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-80
}
threads_get() { [ -f "$THREADS" ] && awk -F'\t' -v k="$1" '$1==k{print $2; exit}' "$THREADS" || true; }
threads_put() {  # key sid subject  -> upsert row: key<TAB>sid<TAB>created<TAB>last_used<TAB>subject
  local k="$1" sid="$2" subj="$3" now created
  now="$(date +%Y-%m-%dT%H:%M:%S)"; touch "$THREADS"
  created="$(awk -F'\t' -v k="$k" '$1==k{print $3; exit}' "$THREADS")"; [ -n "$created" ] || created="$now"
  { awk -F'\t' -v k="$k" 'BEGIN{OFS="\t"} $1!=k{print}' "$THREADS"
    printf '%s\t%s\t%s\t%s\t%s\n' "$k" "$sid" "$created" "$now" "$subj"; } > "$THREADS.tmp" && mv "$THREADS.tmp" "$THREADS"
}
capture_session() {  # echo the UUID of the session file this run just created (newest after $marker)
  local marker="$1" day f b
  day="$CODEX_HOME/sessions/$(date +%Y/%m/%d)"
  f="$(find "$day" -maxdepth 1 -name 'rollout-*.jsonl' -newer "$marker" 2>/dev/null | sort | tail -1)"
  [ -n "$f" ] || return 0
  b="$(basename "$f" .jsonl)"; printf '%s' "${b: -36}"   # trailing 36 chars = the session UUID
}

# 0 if the codex log looks like a transient quota / rate-limit failure
is_quota() { grep -qiE 'rate limit|quota|usage limit|too many requests|429|insufficient_quota' "$1" 2>/dev/null; }

process_one() {
  local f="$1" from subj body ts pfile ofile logf reply rc tkey sid marker newsid mode
  from="$(sed -n 's/^from: //p' "$f" | head -1)"; from="${from:-unknown}"
  subj="$(sed -n 's/^subject: //p' "$f" | head -1)"; subj="${subj:-(no subject)}"
  body="$(awk 'seen{print} /^---$/{c++; if(c==2) seen=1}' "$f")"
  tkey="$(thread_key "$subj")"
  # boundary: codex routes AND threads by SUBJECT — bounce anything with no usable subject
  if [ -z "$tkey" ] || [ "$subj" = "(no subject)" ]; then
    echo "[lab-codex] $(date +%T) rejecting msg from '$from' — no usable subject" >&2
    local note="[codex] Your message reached me without a usable subject line, and I use the SUBJECT as the conversation key (I route and thread by it). Please resend with a short, descriptive subject — e.g.  lab send codex \"phi_ens validity check\" \"...\"  — and reuse that same subject later to continue the thread."
    LAB_FROM="$KEY" "$LAB" send --force "$from" "re: ${subj}" "$note" >/dev/null 2>&1 || true
    mv "$f" "$INBOX/.rejected/" 2>/dev/null || true
    return 0
  fi
  sid="$(threads_get "$tkey")"
  ts="$(date +%Y%m%d-%H%M%S-%N)"
  pfile="$WORK/req-$ts.txt"; ofile="$WORK/out-$ts.md"; logf="$WORK/log-$ts.txt"; marker="$WORK/.mark-$ts"

  if [ -n "$sid" ]; then
    mode="resume $sid"   # continuing thread: codex already holds house rules + prior turns; send only the new message
    printf '=== new message in this thread ===\nFrom session: %s\nSubject: %s\n\n%s\n\n(Reply with the answer itself; it is delivered verbatim to the requester.)\n' \
      "$from" "$subj" "$body" > "$pfile"
  else
    mode="new session"
    { printf '%s\n\n' "$HOUSE"
      printf '=== incoming lab message ===\nFrom session: %s\nSubject: %s\n\n%s\n' "$from" "$subj" "$body"; } > "$pfile"
  fi

  echo "[lab-codex] $(date +%T) handling '$subj' from '$from' [$mode]"
  local mflag=() cflag=()
  [ -n "$MODEL" ] && mflag=(-m "$MODEL")
  [ -n "$REASONING" ] && cflag=(-c "model_reasoning_effort=\"$REASONING\"")
  : > "$marker"   # mark time so capture_session can find the session file this run creates
  rc=0
  if [ -n "$sid" ]; then
    timeout -k 30 "$TIMEOUT" "$CODEX_BIN" -s "$SANDBOX" -a never -C "$PROJECT" "${mflag[@]}" "${cflag[@]}" \
        exec resume "$sid" --skip-git-repo-check --ignore-user-config -o "$ofile" - < "$pfile" > "$logf" 2>&1 || rc=$?
  else
    timeout -k 30 "$TIMEOUT" "$CODEX_BIN" -s "$SANDBOX" -a never -C "$PROJECT" "${mflag[@]}" "${cflag[@]}" \
        exec --skip-git-repo-check --ignore-user-config -o "$ofile" - < "$pfile" > "$logf" 2>&1 || rc=$?
  fi

  # transient quota/rate-limit -> leave the message queued and back off
  if [ "$rc" -ne 0 ] && is_quota "$logf"; then
    echo "[lab-codex] quota/rate-limit (rc=$rc) — leaving '$subj' queued, backing off ${BACKOFF}s" >&2
    rm -f "$marker"; sleep "$BACKOFF"; return 0
  fi

  if [ "$rc" -eq 0 ] && [ -s "$ofile" ]; then
    reply="$(cat "$ofile")"
    if LAB_FROM="$KEY" "$LAB" send --force "$from" "re: $subj" "$reply" >/dev/null 2>&1; then
      echo "[lab-codex] -> replied to '$from' [$mode]"; mv "$f" "$INBOX/.read/" 2>/dev/null || true
    else
      echo "[lab-codex] delivery to '$from' failed — keeping message for retry" >&2
      rm -f "$marker"; return 0
    fi
    # record/refresh the thread's session id (handles resume keeping OR renewing the id)
    newsid="$(capture_session "$marker")"
    if [ -n "$newsid" ]; then threads_put "$tkey" "$newsid" "$subj"
    elif [ -z "$sid" ]; then echo "[lab-codex] warn: could not capture session id for '$subj' — thread not saved" >&2; fi
  else
    local have; [ -s "$ofile" ] && have="present" || have="empty"
    reply="[lab-codex] Your request could not be completed by codex (exit=$rc, output $have). Node-side log: $logf"
    LAB_FROM="$KEY" "$LAB" send --force "$from" "re: $subj" "$reply" >/dev/null 2>&1 || true
    echo "[lab-codex] codex failed on '$subj' from '$from' (rc=$rc) — moved to .failed" >&2
    mv "$f" "$INBOX/.failed/" 2>/dev/null || true
  fi
  rm -f "$marker" 2>/dev/null || true
}

# drain the queue (one call at a time), refresh the heartbeat lock, sleep, repeat
while true; do
  shopt -s nullglob
  for f in "$INBOX"/*.md; do
    process_one "$f" || echo "[lab-codex] error on $(basename "$f") — continuing" >&2
  done
  shopt -u nullglob
  printf '%s %s\n' "$$" "codex-daemon" > "$LOCK"   # heartbeat
  sleep "$INTERVAL" & SLEEP_PID=$!                  # interruptible: SIGTERM stops us promptly
  wait "$SLEEP_PID" 2>/dev/null || true
done
