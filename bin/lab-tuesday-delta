#!/usr/bin/env bash
# Tuesday check-in — NOT a meeting. Asks every session for an incremental update
# since Monday's meeting, sent to the lab manager. Monday's meeting record is the
# base; these deltas amend it, so no second full meeting is convened.
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
set -uo pipefail
export HOME="${HOME:?}"
export LAB_HOME="${LAB_HOME:-$HOME/lab}"
# A syntax error here must not brick every command, so validate before sourcing.
if [ -f "$LAB_HOME/lab.env" ]; then
  if bash -n "$LAB_HOME/lab.env" 2>/dev/null; then set -a; . "$LAB_HOME/lab.env"; set +a
  else echo "lab: WARNING — $LAB_HOME/lab.env has a syntax error and was IGNORED (values with spaces need quotes). Check: bash -n $LAB_HOME/lab.env" >&2; fi
fi

export LAB_FROM=lab-manager
export PATH="$SELF:/usr/local/bin:/usr/bin:/bin"

# Wording is yours: $LAB_HOME/templates/tuesday-delta.md overrides the default below.
if [ -f "$LAB_HOME/templates/tuesday-delta.md" ]; then
  BODY="$(cat "$LAB_HOME/templates/tuesday-delta.md")"
else
read -r -d '' BODY <<'EOF' || true
Tuesday check-in — there is NO meeting in this slot.

If you have NEW results or changes since your Monday meeting post, send them
straight to the lab manager (short is fine — just the delta, not a full update):

  ~/lab/bin/lab send lab-manager "<short subject>" "<what changed since Monday>"

If nothing has changed since Monday, do nothing — no reply needed.

These deltas amend Monday's meeting record; they are not a new meeting. Anything
you send will be folded into the same week's report/slides.
EOF
fi

exec "$SELF/lab" broadcast "Tuesday delta — anything new since Monday's meeting?" "$BODY"
