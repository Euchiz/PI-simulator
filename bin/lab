#!/usr/bin/env bash
# lab — tiny coordination CLI for a multi-session "lab".
# Blackboard lives in $LAB_HOME (default ~/lab). Sessions share this filesystem.
# This file is the DISPATCHER + identity/admin/announce; each family lives in its
# own module beside it (lab-msg, lab-meeting, lab-data, lab-task, lab-roster, lab-ext),
# with shared helpers in lab-common.sh.
set -euo pipefail
. "$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)/lab-common.sh"

usage() {
  local topic="${1:-}"
  case "$topic" in
    msg|message|messaging) cat <<'EOF'
lab — messaging between sessions

  lab who                          Active messenger list: who you can reach now (LIVE/idle/stale)
  lab send <to|@job-id> <subj> [b] Message a CURRENT session (validated; --force to override)
  lab broadcast <subject> <body>   Send the same message to every registered session
  lab inbox [project]              Count unread messages
  lab read [project]               Print your unread messages and mark them read
  lab watch [project]              Stream one line per NEW message (arm via a persistent Monitor)
  lab roster [who|tsv|resolve X]   Raw roster access (who = the same list as `lab who`)

Identity is a STABLE job id, not the name: `lab send @<job-id>` always works, and a
renamed session's mail follows it automatically.
EOF
;;
    task|tasks) cat <<'EOF'
lab — tasks (actionable work; distinct from the announcement board)

  lab task                         Everything outstanding (simplest view)
  lab task list --open             UNCLAIMED only — free for anyone to take
  lab task list [--tagged|--mine|--all|--status S]
  lab task add --title T --desc D [--tag agent] [--priority p]
  lab task take <id>               Claim it — fails if someone already took it
  lab task drop <id>               Release one you cannot finish
  lab task done <id> [--note]      Close it; the creator is notified
  lab task fail <id> --note "why"  A reason is REQUIRED
  lab task show <id> | tag <id> <agent> | cancel <id>

--tag is a SUGGESTION ("see if you can help"), never a reservation: tagged tasks stay
open to anyone. The only rule is you cannot take an already-taken task.
EOF
;;
    meeting|meetings) cat <<'EOF'
lab — meetings (a standup room per meeting, kept by date)

  lab meeting convene [label]      Open a NEW meeting (id = date[-label]); becomes active
  lab meeting post [--file f] <md> Post YOUR update to the active meeting
  lab meeting read [id]            Attend: agenda + everyone's posts
  lab meeting status [id]          Who has / hasn't posted
  lab meeting compile [id]         Freeze into a dated record (MEETING.md + INDEX.md)
  lab meeting list | close
  lab meeting checkin              Between-meeting nudge: ask everyone what's new since last time
EOF
;;
    data|dataset|datasets) cat <<'EOF'
lab — dataset registry (pointers + metadata, never the data itself)

  lab data check <accession>       Dedup gate BEFORE downloading — do we already have it?
  lab data find <query>            Full-text search (name/accession/subset/tags/samples/status)
  lab data add --id … --study … --location … --status … --usage …
  lab data update <id> --status "…" [--verified --verified-how "…"]
  lab data show <id> | list [--tag T]
  lab data mv <id> <newpath>       Record a relocation
  lab data render|export|audit     Human snapshot / CSV backup / dead-path check
  lab data maint                   Run render + export + audit (the daily cron target)

One accession may cover MANY datasets (a SuperSeries/BioProject): register each slice
with the SAME real accession + --subset. Never invent sub-accessions.
EOF
;;
    board|announce) cat <<'EOF'
lab — announcements & status

  lab note <text...>               Append to the ANNOUNCEMENT board (append-only; NOT a to-do list)
  lab board                        Show the announcement board
  lab status <project> <text...>   Set a project's one-line current status
  lab digest                       Mechanical rollup -> digest.md
  lab health                       Run the daily health check now -> HEALTH.md (alerts if flagged)
EOF
;;
    admin|setup) cat <<'EOF'
lab — setup & admin

  lab init [path]                  Create a fresh LAB_HOME (blackboard) skeleton
  lab register <project> [path]    Register a session/project (and wire hooks if path given)
  lab projects                     List registered projects
  lab manager                      Print the text to paste into a new lab-manager session
  lab name | whoami                This session's canonical key / which project this dir maps to
  lab ext [agent] <cmd>            External (non-Claude) reviewers — see `lab ext`

Data lives in $LAB_HOME (default ~/lab); the code lives wherever you installed it.
EOF
;;
    *) cat <<'EOF'
lab — multi-agent coordination for Claude Code sessions ("PI simulator")

  MESSAGING     lab who · send · broadcast · inbox · read · watch
  TASKS         lab task [list|add|take|done|fail|drop|show|tag]
  MEETINGS      lab meeting [convene|post|read|status|compile|list|close|checkin]
  DATA          lab data [check|find|add|update|show|list|mv|render|export|audit|maint]
  ANNOUNCE      lab note · board · status · digest · health
  ADMIN         lab init · register · manager · projects · name · whoami · ext

  lab help <topic>     topics: messaging, tasks, meetings, data, board, admin
  lab <cmd> --help     per-command flags (data/task/ext)

Quick start:  lab init  ·  lab register <name> <path>  ·  lab who  ·  lab task
EOF
;;
  esac
}

cmd_register() {
  ensure_init
  local name; name="$(pkey "${1:?usage: lab register <project> [path]}")"; local path="${2:-}"
  if grep -q "^- \*\*$name\*\*" "$REG" 2>/dev/null; then
    echo "lab: '$name' already registered (updating)"
  else
    printf -- '- **%s** — status: _new_ — path: %s — updated: %s\n' "$name" "${path:-?}" "$(ts)" >> "$REG"
  fi
  mkdir -p "$INBOX/$name" "$INBOX/$name/.read"
  if [ -n "$path" ] && [ -d "$path" ]; then
    install_hooks "$name" "$path"
  fi
  echo "lab: registered '$name'  (inbox: $INBOX/$name)"
}

install_hooks() {
  local name="$1" path="$2"
  local sdir="$path/.claude"; local sfile="$sdir/settings.json"
  mkdir -p "$sdir"
  # SessionStart -> surface unread; Stop -> bump last-active. Idempotent-ish: warn if exists.
  if [ -f "$sfile" ]; then
    echo "lab: $sfile exists — add hooks manually (snippet below):"
  fi
  # Self-resolving: `lab read` with no arg figures out its OWN session name at
  # runtime, so ONE identical hook serves every session that shares this dir.
  cat > "$sdir/lab-hooks.snippet.json" <<EOF
{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "LAB_HOME=$LAB_HOME $LAB_HOME/bin/lab read 2>/dev/null || true" } ] }
    ]
  }
}
EOF
  if [ ! -f "$sfile" ]; then
    cp "$sdir/lab-hooks.snippet.json" "$sfile"
    echo "lab: installed hooks -> $sfile"
  else
    echo "lab: snippet written -> $sdir/lab-hooks.snippet.json (merge its \"hooks\" into $sfile)"
  fi
}

cmd_projects() { ensure_init; grep '^- \*\*' "$REG" || echo "(none registered)"; }

cmd_status() {
  ensure_init
  local name; name="$(pkey "${1:?usage: lab status <project> <text...>}")"; shift
  local text="$*"; [ -n "$text" ] || die "need status text"
  grep -q "^- \*\*$name\*\*" "$REG" || cmd_register "$name" >/dev/null
  local tmp; tmp="$(mktemp)"
  awk -v n="$name" -v s="$text" -v t="$(ts)" '
    $0 ~ "^- \\*\\*" n "\\*\\*" {
      path=$0; sub(/.*path: /,"",path); sub(/ .*/,"",path);
      printf("- **%s** — status: %s — path: %s — updated: %s\n", n, s, path, t); next
    } { print }
  ' "$REG" > "$tmp" && mv "$tmp" "$REG"
  echo "lab: $name -> $text"
}

cmd_init() {
  local target="${1:-$LAB_HOME}"
  mkdir -p "$target"/{inbox,archive,decisions,meeting,alerts,templates,.watch}
  [ -f "$target/registry.md" ] || echo "# Lab registry — sessions/projects, status (managed by \`lab\`)" > "$target/registry.md"
  [ -f "$target/BOARD.md" ]    || printf '# Board — announcements (append-only log, NOT a to-do list)\n\n_Add with `lab note`._\n' > "$target/BOARD.md"
  [ -f "$target/external.tsv" ] || printf '# external (non-Claude) agents: key<TAB>id<TAB>kind<TAB>note\n' > "$target/external.tsv"

  # Config starter. Everything has a working default, so this file is optional —
  # it exists so the knobs are DISCOVERABLE instead of buried in the source.
  # Never overwritten: your settings survive re-running `lab init`.
  if [ ! -f "$target/lab.env" ]; then
    cat > "$target/lab.env" <<'CFG'
# Settings for this install. Sourced automatically by the lab CLI.
# EVERY option has a working default — uncomment only what you want to change.
# Values shown are the defaults. Full list: examples/lab.env.example in the repo.

# ── health check: what counts as "wrong" here ────────────────────────────────
#LAB_STALE_WORKING_H=24     # session marked "working" but untouched this long -> flag
#LAB_INBOX_BACKLOG_H=48     # unread mail older than this -> not picking up coordination
#LAB_TASK_STALE_D=5         # task unclaimed/untouched this many days -> flag
#LAB_BOARD_RECENT_D=7       # window counted as "recent" announcements

# ── daily health check ───────────────────────────────────────────────────────
#LAB_JUDGE=1                # 0 = skip the LLM pass entirely (raw facts, no token spend)
#LAB_JUDGE_MODEL=sonnet     # model for the judgement pass
#LAB_ALERT_CMD=notify-send  # takes "<title>" "<body>". NOTE: notify-send needs a Linux
                            # desktop — on a headless box alerts go NOWHERE unless you
                            # set this (mail/slack/pushover/…).

# ── messaging ────────────────────────────────────────────────────────────────
#LAB_IDLE_MIN=360           # minutes idle before a session stops being a valid send target
#LAB_WATCH_INTERVAL=30      # seconds between inbox polls for `lab watch`

# ── external reviewers (optional; `lab ext`) ─────────────────────────────────
# Each external agent is a self-contained package with its OWN settings file:
#     $LAB_HOME/ext/<agent>/agent.env      <- put per-agent values there, not here
# Anything set below is only a DEFAULT shared by every external agent.
#LAB_EXT_CD=/path/to/project     # working root a reviewer inspects (default: $PWD)
#LAB_EXT_TIMEOUT=900             # seconds per request
#LAB_EXT_INTERVAL=30             # inbox poll seconds
# Tool-specific settings (model, binary, sandbox) belong to that tool's adapter —
# see ext/<agent>/agent.env, created by `lab ext setup <agent>`.
CFG
    echo "lab: wrote $target/lab.env (all options commented at their defaults)"
  else
    echo "lab: kept existing $target/lab.env"
  fi

  echo "lab: initialised blackboard at $target"
  echo
  echo "  It works as-is — every setting has a default. Worth a look before you rely on it:"
  echo "    • LAB_ALERT_CMD   — notify-send does nothing on a headless box; alerts would be silent"
  echo "    • ext/<agent>/agent.env — each external reviewer's own settings (scratch path, timeout)"
  echo "    • the thresholds  — what 'stalled' means depends on your lab's tempo"
  echo "  Custom wording: drop $target/templates/meeting-agenda.md (or checkin.md)"
  echo
  echo "  next:  export LAB_HOME=$target        (add to your shell rc)"
  echo
  echo "  ── Start your lab manager ─────────────────────────────────────────────"
  echo "  Open a NEW Claude Code session, name it \"lab manager\" (any name works),"
  echo "  and paste into it the text printed by:"
  echo
  echo "        lab manager"
  echo
  echo "  That session registers itself, brings your other sessions into the lab, and"
  echo "  from then on runs the standups, health checks and weekly reports for you."
}

cmd_board() { ensure_init; cat "$BOARD"; }

cmd_note() {
  ensure_init
  local from; from="$(resolve_self || project_for_dir || echo "${LAB_FROM:-?}")"
  printf -- '- [ ] %s — %s _(from %s)_\n' "$(date +%Y-%m-%d)" "$*" "$(pkey "$from")" >> "$BOARD"
  echo "lab: noted on board"
}

cmd_digest() {
  ensure_init
  local out="$LAB_HOME/digest.md"
  {
    echo "# Lab digest — $(ts)"
    echo
    echo "## Projects"
    grep '^- \*\*' "$REG" 2>/dev/null || echo "(none)"
    echo
    echo "## Unread inboxes"
    "$SELF/lab-msg" inbox || true
    echo
    echo "## Open board items"
    grep '^- \[ \]' "$BOARD" 2>/dev/null || echo "(none)"
  } > "$out"
  echo "lab: wrote $out"
  cat "$out"
}

# The paste-in text that turns a fresh Claude Code session into this lab's manager.
# Wording is yours: drop a $LAB_HOME/templates/lab-manager.md to replace it ({{manager}}
# is substituted with the configured manager key).
cmd_manager() {
  local tpl="$LAB_HOME/templates/lab-manager.md" body
  if [ -f "$tpl" ]; then body="$(cat "$tpl")"
  else
read -r -d '' body <<'EOF' || true
You are the LAB MANAGER for my multi-agent lab. Set yourself up, then run the lab's
affairs for me.

1. IDENTITY. Run `lab name` to see the key this session resolves to, then
   `lab register <that key>`. If it is not "{{manager}}", append
   LAB_MANAGER="<that key>" to $LAB_HOME/lab.env (quoted) — otherwise the scheduled
   jobs will write to a mailbox nobody reads.
2. LEARN THE SYSTEM. Skim `lab help` and docs/PROTOCOL.md. `lab who` shows who you
   can reach right now.
3. YOUR JOB IS THE LAB'S AFFAIRS, NOT ITS RESEARCH. You convene standups
   (`lab meeting convene`), chase whoever has not posted (`lab meeting status`),
   compile the record (`lab meeting compile`), keep the task bulletin and the
   announcement board tidy (`lab task`, `lab board`), read the daily health check
   (`lab health`), and turn a week of posts into a summary when I ask. If research
   needs doing, post it as a task — do not do it yourself.
4. BRING THE OTHERS IN. Ask me which of my Claude Code sessions belong to this lab,
   register each one (`lab register <name> <project-path>`), and offer to wire their
   SessionStart hooks so they read their mail automatically. Show me the exact diff
   before touching any file inside my projects.
5. SCHEDULE (optional). Offer the jobs in examples/crontab.example — daily health
   check, dataset maintenance, standups, between-meeting check-in. Ask before editing
   my crontab, and put my manager key in the LAB_FROM= of those lines.
6. REPORT BACK in plain English: where the blackboard is, who is registered, what you
   scheduled, and what you deliberately did NOT set up.

After that, when I say "run a standup", "what is stuck?", or "write the weekly
report", handle it with these commands and answer me in plain English.
EOF
  fi
  printf '%s\n' "${body//\{\{manager\}\}/$LAB_MANAGER}"
}

cmd_whoami() { project_for_dir || echo "(this dir maps to no registered project)"; }

cmd_name() {
  local raw; raw="$(resolve_self || true)"
  [ -n "$raw" ] || { echo "(could not resolve session name)"; return 1; }
  [ "${1:-}" = "--raw" ] && { echo "$raw"; return 0; }
  pkey "$raw"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  init)      cmd_init "$@";;
  register)  cmd_register "$@";;
  projects)  cmd_projects "$@";;
  status)    cmd_status "$@";;
  send|broadcast|inbox|read|watch) exec bash "$SELF/lab-msg" "$cmd" "$@";;
  meeting)   exec bash "$SELF/lab-meeting" "$@";;
  board)     cmd_board "$@";;
  who)       exec python3 "$SELF/lab-roster" who;;
  roster)    exec python3 "$SELF/lab-roster" "$@";;
  data)      exec python3 "$SELF/lab-data" "$@";;
  task)      exec python3 "$SELF/lab-task" "$@";;
  ext)       exec bash "$SELF/lab-ext" "$@";;
  note)      cmd_note "$@";;
  digest)    cmd_digest "$@";;
  health)    exec bash "$SELF/lab-daily" "$@";;
  manager)   cmd_manager "$@";;
  whoami)    cmd_whoami "$@";;
  name)      cmd_name "$@";;
  ""|-h|--help|help) usage "${1:-}";;
  *) die "unknown command '$cmd' (try: lab help)";;
esac
