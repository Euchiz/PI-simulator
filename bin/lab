#!/usr/bin/env bash
# lab — tiny coordination CLI for a multi-session "lab".
# Blackboard lives in $LAB_HOME (default ~/lab). Sessions share this filesystem.
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
# Site config: per-install overrides (paths, model, node bin). Never committed —
# the repo ships generic defaults; your deployment sets reality here.
[ -f "$LAB_HOME/lab.env" ] && { set -a; . "$LAB_HOME/lab.env"; set +a; }

REG="$LAB_HOME/registry.md"
BOARD="$LAB_HOME/BOARD.md"
INBOX="$LAB_HOME/inbox"
ARCH="$LAB_HOME/archive"
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"   # dir of this script (for lab-data/lab-roster)

ts()    { date +%Y-%m-%dT%H:%M:%S; }
stamp() { date +%Y%m%d-%H%M%S; }
# canonical project/session key: lowercase, non-alnum -> single dash, trimmed.
pkey()  { echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-50; }
slug()  { pkey "$1"; }
die()   { echo "lab: $*" >&2; exit 1; }

# Resolve THIS background session's own name from the harness, canonicalized.
resolve_self() {
  local sid="${CLAUDE_CODE_SESSION_ID:-}" jd="${CLAUDE_JOB_DIR:-}" st=""
  for cand in "$jd/state.json" "$(dirname "${jd:-/x}")/state.json" "$HOME/.claude/jobs/${sid%%-*}/state.json"; do
    [ -f "$cand" ] && { st="$cand"; break; }
  done
  [ -n "$st" ] || return 1
  python3 -c "import json;print(json.load(open('$st')).get('name',''))" 2>/dev/null
}

# This session's STABLE job id (survives rename + restart/resume). Basename of CLAUDE_JOB_DIR.
session_jobid() {
  local jd="${CLAUDE_JOB_DIR:-}" sid="${CLAUDE_CODE_SESSION_ID:-}"
  if [ -n "$jd" ]; then basename "$jd"; elif [ -n "$sid" ]; then echo "${sid%%-*}"; fi
}

# Rename-follows-mail: if THIS session's name changed since we last saw its job id,
# migrate its inbox old->new and rename its registry key. Keyed on the stable job id.
reconcile_self() {
  local jid cur old roster="$LAB_HOME/.roster.tsv"
  jid="$(session_jobid)"; cur="$(pkey "$(resolve_self || true)")"
  [ -n "$jid" ] && [ -n "$cur" ] || return 0
  [ -f "$roster" ] && old="$(awk -F'\t' -v j="$jid" '$1==j{print $2; exit}' "$roster")" || old=""
  if [ -n "${old:-}" ] && [ "$old" != "$cur" ]; then
    if [ -d "$INBOX/$old" ]; then
      mkdir -p "$INBOX/$cur/.read"
      find "$INBOX/$old" -maxdepth 1 -name '*.md' -exec mv -n {} "$INBOX/$cur/" \; 2>/dev/null || true
      find "$INBOX/$old/.read" -maxdepth 1 -name '*.md' -exec mv -n {} "$INBOX/$cur/.read/" \; 2>/dev/null || true
    fi
    sed -i "s/^- \*\*$old\*\*/- **$cur**/" "$REG" 2>/dev/null || true
    echo "lab: session renamed '$old' -> '$cur' (job $jid); inbox + registry key migrated." >&2
  fi
  touch "$roster"
  awk -F'\t' -v j="$jid" -v c="$cur" -v t="$(ts)" 'BEGIN{OFS="\t"} $1!=j{print} END{print j,c,t}' \
    "$roster" > "$roster.tmp" 2>/dev/null && mv "$roster.tmp" "$roster"
}

usage() {
  local topic="${1:-}"
  case "$topic" in
    msg|message|messaging) cat <<'EOF'
lab — messaging between sessions

  lab who                          Active messenger list: who you can reach now (LIVE/idle/stale)
  lab send <to|@job-id> <subj> [b] Message a CURRENT session (validated; --force to override)
  lab broadcast <subject> <body>   Send the same message to every registered session
  lab inbox [project]              Count unread messages
  lab read [project]               Print your unread messages and mark them read
  lab watch [project]              Stream one line per NEW message (arm via a persistent Monitor)
  lab roster [who|tsv|resolve X]   Raw roster access (who = the same list as `lab who`)

Identity is a STABLE job id, not the name: `lab send @<job-id>` always works, and a
renamed session's mail follows it automatically.
EOF
;;
    task|tasks) cat <<'EOF'
lab — tasks (actionable work; distinct from the announcement board)

  lab task                         Everything outstanding (simplest view)
  lab task list --open             UNCLAIMED only — free for anyone to take
  lab task list [--tagged|--mine|--all|--status S]
  lab task add --title T --desc D [--tag agent] [--priority p]
  lab task take <id>               Claim it — fails if someone already took it
  lab task drop <id>               Release one you cannot finish
  lab task done <id> [--note]      Close it; the creator is notified
  lab task fail <id> --note "why"  A reason is REQUIRED
  lab task show <id> | tag <id> <agent> | cancel <id>

--tag is a SUGGESTION ("see if you can help"), never a reservation: tagged tasks stay
open to anyone. The only rule is you cannot take an already-taken task.
EOF
;;
    meeting|meetings) cat <<'EOF'
lab — meetings (a standup room per meeting, kept by date)

  lab meeting convene [label]      Open a NEW meeting (id = date[-label]); becomes active
  lab meeting post [--file f] <md> Post YOUR update to the active meeting
  lab meeting read [id]            Attend: agenda + everyone's posts
  lab meeting status [id]          Who has / hasn't posted
  lab meeting compile [id]         Freeze into a dated record (MEETING.md + INDEX.md)
  lab meeting list | close
EOF
;;
    data|dataset|datasets) cat <<'EOF'
lab — dataset registry (pointers + metadata, never the data itself)

  lab data check <accession>       Dedup gate BEFORE downloading — do we already have it?
  lab data find <query>            Full-text search (name/accession/subset/tags/samples/status)
  lab data add --id … --study … --location … --status … --usage …
  lab data update <id> --status "…" [--verified --verified-how "…"]
  lab data show <id> | list [--tag T]
  lab data mv <id> <newpath>       Record a relocation
  lab data render|export|audit     Human snapshot / CSV backup / dead-path check

One accession may cover MANY datasets (a SuperSeries/BioProject): register each slice
with the SAME real accession + --subset. Never invent sub-accessions.
EOF
;;
    board|announce) cat <<'EOF'
lab — announcements & status

  lab note <text...>               Append to the ANNOUNCEMENT board (append-only; NOT a to-do list)
  lab board                        Show the announcement board
  lab status <project> <text...>   Set a project's one-line current status
  lab digest                       Mechanical rollup -> digest.md
EOF
;;
    admin|setup) cat <<'EOF'
lab — setup & admin

  lab init [path]                  Create a fresh LAB_HOME (blackboard) skeleton
  lab register <project> [path]    Register a session/project (and wire hooks if path given)
  lab projects                     List registered projects
  lab name | whoami                This session's canonical key / which project this dir maps to
  lab ext [agent] <cmd>            External (non-Claude) reviewers — see `lab ext`

Data lives in $LAB_HOME (default ~/lab); the code lives wherever you installed it.
EOF
;;
    *) cat <<'EOF'
lab — multi-agent coordination for Claude Code sessions ("PI simulator")

  MESSAGING     lab who · send · broadcast · inbox · read · watch
  TASKS         lab task [list|add|take|done|fail|drop|show|tag]
  MEETINGS      lab meeting [convene|post|read|status|compile|list|close]
  DATA          lab data [check|find|add|update|show|list|mv|render|export|audit]
  ANNOUNCE      lab note · board · status · digest
  ADMIN         lab init · register · projects · name · whoami · ext

  lab help <topic>     topics: messaging, tasks, meetings, data, board, admin
  lab <cmd> --help     per-command flags (data/task/ext)

Quick start:  lab init  ·  lab register <name> <path>  ·  lab who  ·  lab task
EOF
;;
  esac
}

ensure_init() {
  [ -f "$REG" ]   || echo "# Lab registry — projects, owners, status (managed by \`lab\`)" > "$REG"
  [ -f "$BOARD" ] || printf '# Board — cross-project issues & dependencies\n\n_Add items with \`lab note\`. Owners check this each session._\n' > "$BOARD"
  mkdir -p "$INBOX" "$ARCH"
}

project_for_dir() {
  # Map current working dir to a project via registry "path:" markers.
  local cwd; cwd="$(pwd)"
  [ -f "$REG" ] || return 1
  local m
  m=$(awk -v cwd="$cwd" '
    /^- \*\*/ { name=$0; sub(/^- \*\*/,"",name); sub(/\*\*.*/,"",name) }
    /path: / { p=$0; sub(/.*path: /,"",p); sub(/ .*/,"",p);
               if (p!="?" && index(cwd, p)==1) { print name } }
  ' "$REG" | head -1)
  [ -n "$m" ] || return 1
  echo "$m"
}

cmd_register() {
  ensure_init
  local name; name="$(pkey "${1:?usage: lab register <project> [path]}")"; local path="${2:-}"
  if grep -q "^- \*\*$name\*\*" "$REG" 2>/dev/null; then
    echo "lab: '$name' already registered (updating)"
  else
    printf -- '- **%s** — status: _new_ — path: %s — updated: %s\n' "$name" "${path:-?}" "$(ts)" >> "$REG"
  fi
  mkdir -p "$INBOX/$name" "$INBOX/$name/.read"
  if [ -n "$path" ] && [ -d "$path" ]; then
    install_hooks "$name" "$path"
  fi
  echo "lab: registered '$name'  (inbox: $INBOX/$name)"
}

install_hooks() {
  local name="$1" path="$2"
  local sdir="$path/.claude"; local sfile="$sdir/settings.json"
  mkdir -p "$sdir"
  # SessionStart -> surface unread; Stop -> bump last-active. Idempotent-ish: warn if exists.
  if [ -f "$sfile" ]; then
    echo "lab: $sfile exists — add hooks manually (snippet below):"
  fi
  # Self-resolving: `lab read` with no arg figures out its OWN session name at
  # runtime, so ONE identical hook serves every session that shares this dir.
  cat > "$sdir/lab-hooks.snippet.json" <<EOF
{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "LAB_HOME=$LAB_HOME $LAB_HOME/bin/lab read 2>/dev/null || true" } ] }
    ]
  }
}
EOF
  if [ ! -f "$sfile" ]; then
    cp "$sdir/lab-hooks.snippet.json" "$sfile"
    echo "lab: installed hooks -> $sfile"
  else
    echo "lab: snippet written -> $sdir/lab-hooks.snippet.json (merge its \"hooks\" into $sfile)"
  fi
}

cmd_projects() { ensure_init; grep '^- \*\*' "$REG" || echo "(none registered)"; }

cmd_status() {
  ensure_init
  local name; name="$(pkey "${1:?usage: lab status <project> <text...>}")"; shift
  local text="$*"; [ -n "$text" ] || die "need status text"
  grep -q "^- \*\*$name\*\*" "$REG" || cmd_register "$name" >/dev/null
  local tmp; tmp="$(mktemp)"
  awk -v n="$name" -v s="$text" -v t="$(ts)" '
    $0 ~ "^- \\*\\*" n "\\*\\*" {
      path=$0; sub(/.*path: /,"",path); sub(/ .*/,"",path);
      printf("- **%s** — status: %s — path: %s — updated: %s\n", n, s, path, t); next
    } { print }
  ' "$REG" > "$tmp" && mv "$tmp" "$REG"
  echo "lab: $name -> $text"
}

cmd_send() {
  ensure_init
  local force=0
  if [ "${1:-}" = "--force" ]; then force=1; shift; fi
  local to_raw="${1:?usage: lab send [--force] <to|@job-id> <subject> [body]}"; local subj="${2:?need subject}"; shift 2 || true
  local body="${*:-}"; [ -n "$body" ] || { [ -t 0 ] || body="$(cat)"; }
  # validate the recipient against the active messenger list (unless --force)
  local to
  if [ "$force" = 1 ]; then
    to="$(pkey "${to_raw#@}")"
  else
    to="$(python3 "$SELF/lab-roster" resolve "$to_raw")" \
      || { echo "lab send: recipient not sent to. Pick a current target above, or use \`lab who\`, \`@<job-id>\`, or --force." >&2; return 1; }
  fi
  local from; from="$(resolve_self || true)"; from="$(pkey "${from:-${LAB_FROM:-$(project_for_dir || echo unknown)}}")"
  mkdir -p "$INBOX/$to"
  [ -d "$INBOX/$to" ] || die "no inbox for '$to' — register it first"
  local f="$INBOX/$to/$(stamp)__from-$(slug "$from")__$(slug "$subj").md"
  cat > "$f" <<EOF
---
from: $from
to: $to
date: $(ts)
subject: $subj
status: unread
---

$body
EOF
  echo "lab: message -> $to  ($(basename "$f"))"
}

cmd_broadcast() {
  ensure_init
  local subj="${1:?usage: lab broadcast <subject> <body>}"; shift || true
  local body="${*:-}"; [ -n "$body" ] || { [ -t 0 ] || body="$(cat)"; }
  [ -n "$body" ] || die "usage: lab broadcast <subject> <body>|<stdin>"
  local sent=0
  while read -r key; do
    [ -n "$key" ] || continue
    cmd_send --force "$key" "$subj" "$body" >/dev/null   # fan-out: reach every registered inbox
    sent=$((sent+1))
  done < <(grep '^- \*\*' "$REG" 2>/dev/null | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')
  echo "lab: broadcast to $sent sessions — \"$subj\""
}

cmd_inbox() {
  ensure_init
  if [ -n "${1:-}" ]; then
    local n; n="$(pkey "$1")"; local c; c=$(find "$INBOX/$n" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l)
    echo "$n: $c unread"
  else
    for d in "$INBOX"/*/; do
      [ -d "$d" ] || continue; local n; n=$(basename "$d")
      local c; c=$(find "$d" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l)
      [ "$c" -gt 0 ] && echo "$n: $c unread"
    done
  fi
}

cmd_read() {
  ensure_init
  reconcile_self   # if this session was renamed, its mail follows it before we read
  local n; n="$(pkey "${1:-$(resolve_self)}")"; [ -n "$n" ] || die "usage: lab read <project>"
  local any=0
  mkdir -p "$INBOX/$n/.read"   # ad-hoc inboxes (e.g. codex replies to an unregistered name) lack it
  for f in "$INBOX/$n"/*.md; do
    [ -e "$f" ] || continue; any=1
    echo "════════════════════════════════════════"
    cat "$f"
    echo
    mv "$f" "$INBOX/$n/.read/"
  done
  [ "$any" = 1 ] || echo "[$n] inbox empty"
}

cmd_init() {
  local target="${1:-$LAB_HOME}"
  mkdir -p "$target"/{inbox,archive,decisions,meeting,alerts,.watch}
  [ -f "$target/registry.md" ] || echo "# Lab registry — sessions/projects, status (managed by \`lab\`)" > "$target/registry.md"
  [ -f "$target/BOARD.md" ]    || printf '# Board — announcements (append-only log, NOT a to-do list)\n\n_Add with `lab note`._\n' > "$target/BOARD.md"
  [ -f "$target/external.tsv" ] || printf '# external (non-Claude) agents: key<TAB>id<TAB>kind<TAB>note\n' > "$target/external.tsv"
  echo "lab: initialised blackboard at $target"
  echo "  next:  export LAB_HOME=$target   (add to your shell rc)"
  echo "         lab register <session-name> [project-path]"
}

cmd_board() { ensure_init; cat "$BOARD"; }

# Emit one line describing a message file (stdout line = one Monitor event).
watch_emit() {
  local f="$1"; [ -f "$f" ] || return 0
  local from subj
  from="$(sed -n 's/^from: //p' "$f" | head -1)"
  subj="$(sed -n 's/^subject: //p' "$f" | head -1)"
  echo "NEW lab message — from ${from:-?}: ${subj:-(no subject)}  → run: ~/lab/bin/lab read"
}

# Long-lived watcher: prints one line per NEW inbox message, forever.
# Designed to be armed via the Monitor tool (persistent) so each line becomes a
# notification. Cheap by construction: `ls` on ONE tiny inbox dir, never a scan.
# NOTE: ~/lab is NFS and inotify is unavailable/unreliable there -> poll.
cmd_watch() {
  ensure_init
  reconcile_self   # pick up a rename before we start watching an inbox
  local n; n="$(pkey "${1:-$(resolve_self || true)}")"
  [ -n "$n" ] || die "usage: lab watch [project]  (or run inside a registered session)"
  local dir="$INBOX/$n"; mkdir -p "$dir"
  local interval="${LAB_WATCH_INTERVAL:-30}"

  # --- single-watcher guard (idempotent, SESSION-AWARE) -----------------------
  # SessionStart fires on resume/compact too, so an agent may arm the watcher
  # several times in ONE session -> a duplicate exits harmlessly (ends its Monitor).
  #
  # But an agent's OLD session can leak a still-running watcher. That stale watcher
  # must NOT block the live session (it would silently get no delivery, and would
  # keep eating this inbox's mail). So the lock records "<pid> <session-id>":
  #   same session + alive  -> genuine duplicate, exit
  #   other session         -> superseded; TAKE OVER the lock and warn
  #   dead pid              -> stale; take over
  local lockdir="$LAB_HOME/.watch"; mkdir -p "$lockdir"
  local lock="$lockdir/$n.lock" old_pid old_sid
  local my_sid="${CLAUDE_CODE_SESSION_ID:-unknown}"
  if [ -f "$lock" ]; then
    read -r old_pid old_sid < "$lock" 2>/dev/null || true
    if [ -n "${old_pid:-}" ] && [ "$old_pid" != "$$" ] && kill -0 "$old_pid" 2>/dev/null; then
      if [ "${old_sid:-}" = "$my_sid" ]; then
        echo "lab watch: already watching '$n' (pid $old_pid, this session) — duplicate exiting."
        return 0
      fi
      echo "lab watch: taking over '$n' from a SUPERSEDED session (stale pid $old_pid, sid ${old_sid:-?}). That process is still running and should be killed: kill $old_pid"
    fi
  fi
  printf '%s %s\n' "$$" "$my_sid" > "$lock"
  trap 'rm -f "$lock" 2>/dev/null' EXIT INT TERM
  # ---------------------------------------------------------------------------
  local seen cur new f
  seen="$( (cd "$dir" && ls -1 -- *.md 2>/dev/null) | sort || true )"
  # announce anything already waiting, then stream new arrivals
  while IFS= read -r f; do [ -n "$f" ] && watch_emit "$dir/$f"; done <<< "$seen"
  while true; do
    sleep "$interval"
    cur="$( (cd "$dir" && ls -1 -- *.md 2>/dev/null) | sort || true )"
    new="$(comm -13 <(printf '%s\n' "$seen") <(printf '%s\n' "$cur") 2>/dev/null || true)"
    while IFS= read -r f; do [ -n "$f" ] && watch_emit "$dir/$f"; done <<< "$new"
    seen="$cur"
  done
}

cmd_note() {
  ensure_init
  local from; from="$(resolve_self || project_for_dir || echo "${LAB_FROM:-?}")"
  printf -- '- [ ] %s — %s _(from %s)_\n' "$(date +%Y-%m-%d)" "$*" "$(pkey "$from")" >> "$BOARD"
  echo "lab: noted on board"
}

cmd_digest() {
  ensure_init
  local out="$LAB_HOME/digest.md"
  {
    echo "# Lab digest — $(ts)"
    echo
    echo "## Projects"
    grep '^- \*\*' "$REG" 2>/dev/null || echo "(none)"
    echo
    echo "## Unread inboxes"
    cmd_inbox || true
    echo
    echo "## Open board items"
    grep '^- \[ \]' "$BOARD" 2>/dev/null || echo "(none)"
  } > "$out"
  echo "lab: wrote $out"
  cat "$out"
}

cmd_whoami() { project_for_dir || echo "(this dir maps to no registered project)"; }

cmd_name() {
  local raw; raw="$(resolve_self || true)"
  [ -n "$raw" ] || { echo "(could not resolve session name)"; return 1; }
  [ "${1:-}" = "--raw" ] && { echo "$raw"; return 0; }
  pkey "$raw"
}

# ---- lab meetings (standup rooms, separate from the board) ----
# Keyed by date + optional label (e.g. 2026-06-24, 2026-06-24-results), so you can
# hold several per week. One meeting is "active" at a time; posts land in it.
# Records are kept by date under $MEET/<id>/.
MEET="$LAB_HOME/meeting"
ACTIVE="$MEET/.active"

meet_active() { [ -f "$ACTIVE" ] && cat "$ACTIVE" 2>/dev/null || true; }
meet_latest() { local d last=""; for d in "$MEET"/*/; do [ -d "$d" ] || continue; last="$(basename "$d")"; done; echo "$last"; }
meet_resolve() {
  local a="${1:-}"
  if [ -n "$a" ]; then
    if [ -d "$MEET/$a" ]; then echo "$a"; return; fi
    local d hit=""                                   # fuzzy: match by label substring, newest wins
    for d in "$MEET"/*/; do [ -d "$d" ] || continue; case "$(basename "$d")" in *"$a"*) hit="$(basename "$d")";; esac; done
    echo "${hit:-$a}"; return
  fi
  local x; x="$(meet_active)"; [ -n "$x" ] && { echo "$x"; return; }
  meet_latest
}

cmd_meeting() {
  ensure_init
  local sub="${1:-read}"; shift || true
  case "$sub" in
    convene) meeting_convene "$@";;
    post)    meeting_post "$@";;
    read|attend) meeting_read "$@";;
    status)  meeting_status "$@";;
    compile|archive) meeting_compile "$@";;
    list|ls) meeting_list "$@";;
    close)   rm -f "$ACTIVE"; echo "lab: active meeting closed (records kept)";;
    room)    echo "$MEET/$(meet_resolve "${1:-}")";;
    *) die "lab meeting: convene [label] | post [--file f] <md> | read [id] | status [id] | compile [id] | list | close";;
  esac
}

meeting_convene() {
  local label="${1:-}"
  local base; base="$(date +%Y-%m-%d)"; [ -n "$label" ] && base="$base-$(pkey "$label")"
  local id="$base" n=2
  while [ -d "$MEET/$id" ]; do id="$base-$n"; n=$((n+1)); done   # unique even for several/day
  local dir="$MEET/$id"; mkdir -p "$dir/posts" "$dir/assets"
  cat > "$dir/AGENDA.md" <<EOF
# Lab meeting — $id
Convened: $(ts)

Post a full lab-meeting update — share the real thing, as long as it needs to be:
  - what you worked on and the KEY RESULTS: numbers, tables, comparisons
  - figures/plots — embed by absolute path, e.g.  ![desc](/abs/path/plot.png)
    or drop images into this folder's  assets/  and reference them
  - blockers, open questions, and next steps

Post it (use --file for a longer doc with tables/figures):
  ~/lab/bin/lab meeting post "<markdown update>"
  ~/lab/bin/lab meeting post --file my_update.md
Then attend — read everyone else's:
  ~/lab/bin/lab meeting read
EOF
  echo "$id" > "$ACTIVE"
  local sent=0
  while read -r key; do
    [ -n "$key" ] || continue
    cmd_send --force "$key" "lab meeting $id — post your update" \
"Lab meeting '$id' is open. Post a FULL update — key results (numbers, tables),
figures (embed by absolute path or drop in $dir/assets/), blockers, and next
steps. As long as it needs to be; this is a lab meeting, not a status line.
  ~/lab/bin/lab meeting post \"<markdown>\"       # short
  ~/lab/bin/lab meeting post --file update.md      # longer doc with figures/tables
Then see everyone else's:  ~/lab/bin/lab meeting read" >/dev/null
    sent=$((sent+1))
  done < <(grep '^- \*\*' "$REG" 2>/dev/null | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')
  echo "lab: meeting '$id' convened (now active) — agenda at $dir/AGENDA.md, requested $sent sessions"
}

meeting_compile() {
  local id; id="$(meet_resolve "${1:-}")"; local dir="$MEET/$id"
  [ -n "$id" ] && [ -d "$dir" ] || die "no meeting to compile (convene one first)"
  local out="$dir/MEETING.md"; local n
  n="$(find "$dir/posts" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l)"
  {
    echo "# Lab meeting record — $id"
    echo "_Compiled $(ts) · $n posts_"
    echo
    [ -f "$dir/AGENDA.md" ] && { echo "## Agenda"; echo; cat "$dir/AGENDA.md"; echo; }
    echo "## Posts"
    echo
    for f in "$dir"/posts/*.md; do
      [ -e "$f" ] || continue
      local name src posted tag
      name="$(basename "$f" .md)"
      src="$(sed -n 's/^source: //p' "$f" | head -1)"
      posted="$(sed -n 's/^posted: //p' "$f" | head -1)"
      tag=""; [ "${src:-self}" != "self" ] && tag=" _(${src})_"
      echo "### ${name}${tag}"
      [ -n "$posted" ] && echo "_posted: ${posted}_"
      echo
      sed '1,/^---$/d; /^---$/d' "$f" 2>/dev/null | sed '/./,$!d'
      echo
    done
  } > "$out"
  local idx="$MEET/INDEX.md"
  [ -f "$idx" ] || echo "# Lab meeting records (by date)" > "$idx"
  grep -q "meeting/$id/MEETING.md" "$idx" 2>/dev/null \
    || echo "- **$id** — compiled $(date +%Y-%m-%d), $n posts — [record](meeting/$id/MEETING.md)" >> "$idx"
  echo "lab: compiled record -> $out  (indexed in $idx)"
}

meeting_post() {
  local as="" source="self" file=""
  while true; do
    case "${1:-}" in
      --as)   as="$2"; source="auto-seed (transcript)"; shift 2;;
      --file) file="$2"; shift 2;;
      *) break;;
    esac
  done
  local text
  if [ -n "$file" ]; then [ -f "$file" ] || die "no such file: $file"; text="$(cat "$file")"
  else text="$*"; [ -n "$text" ] || { [ -t 0 ] || text="$(cat)"; }; fi
  [ -n "$text" ] || die "usage: lab meeting post [--as <key>] [--file <path>] <markdown>|<stdin>"
  local self
  if [ -n "$as" ]; then self="$(pkey "$as")"
  else self="$(resolve_self || true)"; self="$(pkey "${self:-${LAB_FROM:-}}")"; fi
  [ -n "$self" ] || die "could not resolve your session name (set LAB_FROM=<name>)"
  local id; id="$(meet_active)"; [ -n "$id" ] || die "no active meeting — convene one: lab meeting convene"
  mkdir -p "$MEET/$id/posts"
  local f="$MEET/$id/posts/$self.md"
  cat > "$f" <<EOF
---
session: $self
meeting: $id
posted: $(ts)
source: $source
---

$text
EOF
  echo "lab: posted to meeting '$id' as '$self' (source: $source)"
}

meeting_read() {
  local id; id="$(meet_resolve "${1:-}")"; local dir="$MEET/$id"
  [ -n "$id" ] && [ -d "$dir" ] || { echo "[no meeting — convene with: lab meeting convene]"; return 0; }
  [ -f "$dir/AGENDA.md" ] && cat "$dir/AGENDA.md"
  echo; echo "════════ posts ════════"
  local any=0
  for f in "$dir"/posts/*.md; do
    [ -e "$f" ] || continue; any=1
    local src; src="$(sed -n 's/^source: //p' "$f" | head -1)"
    local tag=""; [ "${src:-self}" != "self" ] && tag="  [${src}]"
    echo "── $(basename "$f" .md)$tag ──"
    sed '1,/^---$/d; /^---$/d' "$f" 2>/dev/null | sed '/./,$!d'
    echo
  done
  [ "$any" = 1 ] || echo "(no posts yet)"
}

meeting_status() {
  local id; id="$(meet_resolve "${1:-}")"; local dir="$MEET/$id"
  [ -n "$id" ] || { echo "(no meetings yet — convene one)"; return 0; }
  echo "Meeting '$id' — attendance:"
  while read -r key; do
    [ -n "$key" ] || continue
    if [ -f "$dir/posts/$key.md" ]; then echo "  [x] $key (posted)"; else echo "  [ ] $key (pending)"; fi
  done < <(grep '^- \*\*' "$REG" 2>/dev/null | sed -E 's/^- \*\*([^*]+)\*\*.*/\1/')
}

meeting_list() {
  local act; act="$(meet_active)"; local d id n any=0
  echo "Meetings (* = active):"
  for d in "$MEET"/*/; do
    [ -d "$d" ] || continue; any=1
    id="$(basename "$d")"
    n="$(find "$d/posts" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l)"
    local mark="  "; [ "$id" = "$act" ] && mark=" *"
    local comp=""; [ -f "$d/MEETING.md" ] && comp=" — compiled"
    echo "$mark $id — $n posts$comp"
  done
  [ "$any" = 1 ] || echo "  (none yet)"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  init)     cmd_init "$@";;
  register) cmd_register "$@";;
  projects) cmd_projects "$@";;
  status)   cmd_status "$@";;
  send)     cmd_send "$@";;
  broadcast) cmd_broadcast "$@";;
  inbox)    cmd_inbox "$@";;
  read)     cmd_read "$@";;
  board)    cmd_board "$@";;
  watch)    cmd_watch "$@";;
  who)      exec python3 "$SELF/lab-roster" who;;
  roster)   exec python3 "$SELF/lab-roster" "$@";;
  data)     exec python3 "$SELF/lab-data" "$@";;
  task)     exec python3 "$SELF/lab-task" "$@";;
  ext)      exec bash "$SELF/lab-ext" "$@";;
  note)     cmd_note "$@";;
  digest)   cmd_digest "$@";;
  whoami)   cmd_whoami "$@";;
  name)     cmd_name "$@";;
  meeting)  cmd_meeting "$@";;
  ""|-h|--help|help) usage "${1:-}";;
  *) die "unknown command '$cmd' (try: lab help)";;
esac
