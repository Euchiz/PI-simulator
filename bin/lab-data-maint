#!/usr/bin/env bash
# Daily dataset-registry maintenance (cron). NOT on the write path.
#   render  -> ~/lab/DATASETS.md   (human snapshot)
#   export  -> ~/lab/datasets.csv  (git-diffable backup)
#   audit   -> stat every registered path (never walks a tree); flag dead links
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export LAB_HOME="${LAB_HOME:-$HOME/lab}"
# A syntax error here must not brick every command, so validate before sourcing.
if [ -f "$LAB_HOME/lab.env" ]; then
  if bash -n "$LAB_HOME/lab.env" 2>/dev/null; then set -a; . "$LAB_HOME/lab.env"; set +a
  else echo "lab: WARNING — $LAB_HOME/lab.env has a syntax error and was IGNORED (values with spaces need quotes). Check: bash -n $LAB_HOME/lab.env" >&2; fi
fi

export PATH="/usr/local/bin:/usr/bin:/bin"
D="$SELF/lab-data"
echo "=== lab-data maint $(date) ==="
python3 "$D" render
python3 "$D" export
python3 "$D" audit || true    # audit exits 2 when paths are missing; that's a report, not a failure
