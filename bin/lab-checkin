#!/usr/bin/env bash
# Between-meeting check-in — NOT a meeting. Asks every session for an incremental
# update since the last meeting, sent to the lab manager. The last meeting record is
# the base; these updates amend it, so no second full meeting is convened.
# Schedule it on whatever day suits your lab — the day lives in your crontab, not here.
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
set -uo pipefail
export HOME="${HOME:?}"
export LAB_HOME="${LAB_HOME:-$HOME/lab}"
# A syntax error here must not brick every command, so validate before sourcing.
if [ -f "$LAB_HOME/lab.env" ]; then
  if bash -n "$LAB_HOME/lab.env" 2>/dev/null; then set -a; . "$LAB_HOME/lab.env"; set +a
  else echo "lab: WARNING — $LAB_HOME/lab.env has a syntax error and was IGNORED (values with spaces need quotes). Check: bash -n $LAB_HOME/lab.env" >&2; fi
fi

export LAB_FROM=lab-manager
export PATH="$SELF:/usr/local/bin:/usr/bin:/bin"

# Wording is yours: $LAB_HOME/templates/checkin.md overrides the default below.
if [ -f "$LAB_HOME/templates/checkin.md" ]; then
  BODY="$(cat "$LAB_HOME/templates/checkin.md")"
else
read -r -d '' BODY <<'EOF' || true
Check-in — there is NO meeting in this slot.

If you have NEW results or changes since your last meeting post, send them
straight to the lab manager (short is fine — just what's new, not a full update):

  ~/lab/bin/lab send lab-manager "<short subject>" "<what changed since the last meeting>"

If nothing has changed, do nothing — no reply needed.

These updates amend the last meeting's record; they are not a new meeting. Anything
you send will be folded into the same week's report/slides.
EOF
fi

exec "$SELF/lab" broadcast "Check-in — anything new since the last meeting?" "$BODY"
