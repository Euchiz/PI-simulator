#!/usr/bin/env bash
# lab-ext — manage EXTERNAL lab agents: a coding CLI (Codex, Gemini CLI, Aider, opencode, …)
# run as a lab peer that any session can ask for an independent review.
#
#   lab ext                          list external agents and whether they're up
#   lab ext setup <agent>            scaffold an adapter for your CLI, then guide you through it
#   lab ext <agent> start            launch its daemon (detached, survives your shell)
#   lab ext <agent> stop|restart     stop / bounce it
#   lab ext <agent> status           running? pid, uptime, inbox queue, last log lines
#   lab ext <agent> logs [-f]        show (or follow) the daemon log
#   lab ext <agent> send <subj> <body>   ask it; the SUBJECT is the thread key
#   lab ext <agent> threads          list conversation threads (subject -> session -> last used)
#   lab ext <agent> chat [args]      interactive session, if the adapter supports it
#   lab ext keepalive [agent]        (re)start its daemon if it's down — idempotent, for cron
#
# Each agent needs an ADAPTER: a small shell file saying how to run that one CLI.
# `lab ext setup <agent>` creates it from a template. The lab side — inbox, threading,
# delivery, retries — is handled by lab-bridge and is the same for every tool.
set -uo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
# A syntax error here must not brick every command, so validate before sourcing.
if [ -f "$LAB_HOME/lab.env" ]; then
  if bash -n "$LAB_HOME/lab.env" 2>/dev/null; then set -a; . "$LAB_HOME/lab.env"; set +a
  else echo "lab: WARNING — $LAB_HOME/lab.env has a syntax error and was IGNORED (values with spaces need quotes). Check: bash -n $LAB_HOME/lab.env" >&2; fi
fi
SELF="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

LAB="$SELF/lab"
EXT="$LAB_HOME/external.tsv"
DAEMON="$SELF/lab-bridge"
. "$SELF/lab-ext-common.sh"    # the per-agent package layout
[ -n "${LAB_NODE_BIN:-}" ] && export PATH="$LAB_NODE_BIN:$PATH"

die(){ echo "lab ext: $*" >&2; exit 1; }
usage(){ awk 'NR>1 && /^#/{sub(/^# ?/,""); print; next} NR>1{exit}' "$0"; }
thread_key(){ printf '%s' "$1" | sed -E 's/^([[:space:]]*[Rr][Ee]:[[:space:]]*)+//' | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-80; }

# --- per-agent paths: one definition, shared with the daemon (lab-ext-common.sh) ---
use_agent() { ext_paths "$1"; }
threads_get(){ [ -f "$THREADS" ] && awk -F'\t' -v k="$1" '$1==k{print $2; exit}' "$THREADS" || true; }
running_pid() {
  [ -f "$LOCK" ] || return 0
  local p; p="$(cut -d' ' -f1 "$LOCK" 2>/dev/null || true)"
  { [ -n "$p" ] && [ -d "/proc/$p" ]; } || return 0
  tr '\0' ' ' < "/proc/$p/cmdline" 2>/dev/null | grep -q 'lab-bridge' && echo "$p" || true
}

# Every agent that is INSTALLED (has a package) or REGISTERED (row in external.tsv).
# Paths are computed inline here rather than via ext_paths(), so listing one agent never
# leaves another agent's settings loaded in this shell.
ext_agent_keys() {
  { ext_list_agents; cut -f1 "$EXT" 2>/dev/null | grep -v '^#'; } | sed '/^$/d' | sort -u
}

ext_has_adapter() {
  [ -f "$LAB_HOME/ext/$1/adapter.sh" ] || [ -f "$LAB_HOME/adapters/$1.sh" ] \
    || [ -f "$SELF/../adapters/$1.sh" ]
}

ext_list() {
  echo "External lab agents ($LAB_HOME/ext):"
  local keys k p st note n=0
  keys="$(ext_agent_keys)"
  if [ -z "$keys" ]; then
    echo "  (none installed)"; echo; echo "  add one:  lab ext setup <agent>"; return 0
  fi
  while read -r k; do
    [ -n "$k" ] || continue
    LOCK="$LAB_HOME/.watch/$k.lock"; p="$(running_pid)"; st="down"
    [ -n "$p" ] && st="LIVE (pid $p)"
    ext_has_adapter "$k" || st="$st  [no adapter]"
    note="$(awk -F'\t' -v k="$k" '$1==k{print $4; exit}' "$EXT" 2>/dev/null)"
    printf "  %-12s %-22s %s\n" "$k" "$st" "${note:-}"; n=$((n+1))
  done <<EOF
$keys
EOF
  echo
  echo "each agent is a package:  $LAB_HOME/ext/<agent>/  (adapter.sh, agent.env, threads, work/)"
  echo "manage:  lab ext <agent> <start|stop|restart|status|logs|send|threads|chat>"
  echo "add:     lab ext setup <agent>"
}

# --- setup: scaffold an adapter and walk the user/agent through it ---
ext_setup() {
  local key; key="$(printf '%s' "${1:?usage: lab ext setup <agent>}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  ext_migrate_legacy "$key"
  use_agent "$key"
  local pkg="$LAB_HOME/ext/$key"
  local dest="$pkg/adapter.sh"
  mkdir -p "$pkg/work"
  # this agent's own settings file — per-agent values beat the global lab.env
  if [ ! -f "$pkg/agent.env" ]; then
    cat > "$pkg/agent.env" <<AENV
# Settings for the '$key' external agent only. Sourced after \$LAB_HOME/lab.env, so these
# win over the global values; a variable set on the command line still wins over both.
# Uncomment what you need — every one of them has a working default.
#: "\${LAB_EXT_CD:=/path/to/the/repo/it/reviews}"   # working root (default: \$PWD)
#: "\${LAB_EXT_WORK:=/path/to/scratch/$key}"        # scratch; move OFF \$HOME if transcripts grow
#: "\${LAB_EXT_TIMEOUT:=900}"                       # seconds per request
#: "\${LAB_EXT_INTERVAL:=30}"                       # inbox poll seconds
#: "\${LAB_EXT_BACKOFF:=900}"                       # sleep after a rate limit
# Tool settings belong here too, e.g.:  #: "\${MY_CLI_MODEL:=fast}"
AENV
    echo "lab ext: created $pkg/agent.env"
  fi
  if [ -f "$dest" ]; then
    echo "lab ext: adapter already exists: $dest"
  else
    local tpl=""
    for c in "$SELF/../adapters/TEMPLATE.sh" "$LAB_HOME/adapters/TEMPLATE.sh"; do
      [ -f "$c" ] && { tpl="$c"; break; }
    done
    [ -n "$tpl" ] || die "adapter template not found (expected adapters/TEMPLATE.sh next to the install)"
    sed "s/{{agent}}/$key/g" "$tpl" > "$dest"
    echo "lab ext: created $dest"
  fi
  # register it so `lab who` / `lab send` know the name
  local TAB; TAB="$(printf '\t')"; touch "$EXT"
  grep -q "^${key}${TAB}" "$EXT" 2>/dev/null \
    || printf '%s\t%s\texternal\t%s\n' "$key" "$key" "external reviewer ($key)" >> "$EXT"

  cat <<EOF

Next — teach it how to run your CLI. Edit:
    $dest

You only implement ONE required function, adapter_run():
  read the request from  \$PROMPT_FILE
  write the reply to     \$OUT_FILE      <- delivered verbatim to whoever asked
  write noise to         \$LOG_FILE
  resume a conversation with \$SESSION_ID (empty = new thread)
  inspect the project at \$PROJECT       <- keep it READ-ONLY
Optional: adapter_preflight, adapter_capture_session (threading), adapter_is_transient (rate limits).
A worked example ships at: $SELF/../adapters/codex.sh

Put settings (model, binary path, sandbox flags) in $LAB_HOME/lab.env and read them
in the adapter with defaults, e.g.  MY_MODEL="\${MY_CLI_MODEL:-default}".

Then:
    lab ext $key start      # launch it
    lab ext $key status     # confirm it came up
    lab ext $key send "smoke test" "Reply with OK if you can read this."
    lab read \$(lab name)    # its answer lands in your inbox
EOF
}

agent_start() {
  ext_migrate_legacy "$KEY"; ext_paths "$KEY"   # fold a pre-package install into ext/<agent>/
  mkdir -p "$PKG/work"
  local p; p="$(running_pid)"
  [ -n "$p" ] && { echo "$KEY daemon already running (pid $p)."; return 0; }
  [ -x "$DAEMON" ] || die "bridge not found or not executable: $DAEMON"
  [ -n "$ADAPTER" ] || die "no adapter for '$KEY' — create one:  lab ext setup $KEY"
  mkdir -p "$LOGDIR"
  echo "-- $(date '+%F %T') lab ext $KEY start (adapter=$ADAPTER) --" >> "$LOG"
  setsid "$DAEMON" "$KEY" >>"$LOG" 2>&1 </dev/null &
  local i; for i in $(seq 1 12); do sleep 0.5; [ -n "$(running_pid)" ] && break; done
  p="$(running_pid)"
  if [ -n "$p" ]; then
    echo "$KEY daemon started (pid $p).  follow it:  lab ext $KEY logs -f"
  else
    echo "$KEY daemon did NOT come up — see:  lab ext $KEY logs" >&2
    tail -n 8 "$LOG" 2>/dev/null | sed 's/^/  /' >&2 || true
    return 1
  fi
}

agent_stop() {
  local p; p="$(running_pid)"
  [ -n "$p" ] || { echo "$KEY daemon not running."; rm -f "$LOCK" 2>/dev/null || true; return 0; }
  kill -TERM "$p" 2>/dev/null || true
  local i; for i in $(seq 1 10); do [ -d "/proc/$p" ] || break; sleep 0.5; done
  [ -d "/proc/$p" ] && { kill -9 "$p" 2>/dev/null || true; sleep 0.5; }
  rm -f "$LOCK" 2>/dev/null || true
  echo "$KEY daemon stopped (was pid $p)."
}

agent_status() {
  local p; p="$(running_pid)"
  if [ -n "$p" ]; then
    local et; et="$(ps -o etimes= -p "$p" 2>/dev/null | tr -d ' ' || true)"
    echo "$KEY daemon: LIVE  (pid $p, up ${et:-?}s)"
  else
    echo "$KEY daemon: down"
  fi
  local q r fdir rj nt
  q="$(find "$INBOX" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l || true)"
  r="$(find "$INBOX/.read" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l || true)"
  fdir="$(find "$INBOX/.failed" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l || true)"
  rj="$(find "$INBOX/.rejected" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l || true)"
  echo "  inbox: $q queued · $r answered · $fdir failed · $rj rejected(no-subject)"
  nt="$([ -f "$THREADS" ] && grep -c . "$THREADS" 2>/dev/null || echo 0)"
  echo "  threads: ${nt} conversation(s)  —  lab ext $KEY threads"
  echo "  adapter=${ADAPTER:-NONE}  cd=${LAB_EXT_CD:-$PWD}"
  if [ -f "$LOG" ]; then echo "  --- last log ---"; tail -n 6 "$LOG" 2>/dev/null | sed 's/^/  /'; fi
}

agent_logs() {
  [ -f "$LOG" ] || die "no log yet ($LOG). Start it:  lab ext $KEY start"
  case "${1:-}" in -f|--follow) exec tail -n 40 -f "$LOG";; *) tail -n 40 "$LOG";; esac
}

agent_send() {
  local subj="${1:?usage: lab ext <agent> send <subject> <body>}"; shift || true
  local body="${*:-}"; [ -n "$body" ] || { [ -t 0 ] || body="$(cat)"; }
  [ -n "$body" ] || die "need a body"
  local me="${LAB_FROM:-${LAB_MANAGER:-lab-manager}}"
  LAB_FROM="$me" "$LAB" send "$KEY" "$subj" "$body"
  echo "sent to $KEY as '$me' — read the reply with:  lab read $me"
  echo "(same subject later = same conversation; new subject = fresh session)"
}

agent_threads() {
  [ -s "$THREADS" ] || { echo "no $KEY conversation threads yet."; return 0; }
  printf "  %-40s %-38s %s\n" "SUBJECT" "SESSION" "LAST-USED"
  awk -F'\t' '{s=$5; if(length(s)>40) s=substr(s,1,38)".."; printf "  %-40s %-38s %s\n", s, $2, $4}' "$THREADS"
  echo; echo "resume one interactively:  lab ext $KEY chat \"<subject>\""
}

# Interactive chat is tool-specific: only available if the adapter implements adapter_chat.
agent_chat() {
  [ -n "$ADAPTER" ] || die "no adapter for '$KEY' — run:  lab ext setup $KEY"
  # shellcheck disable=SC1090
  . "$ADAPTER"
  command -v adapter_chat >/dev/null || die "'$KEY' has no interactive chat (its adapter defines no adapter_chat). Use:  lab ext $KEY send \"<subject>\" \"<body>\""
  local sid=""
  [ -n "${1:-}" ] && sid="$(threads_get "$(thread_key "$1")")"
  PROJECT="${LAB_EXT_CD:-$PWD}" SESSION_ID="$sid" AGENT="$KEY" adapter_chat "$@"
}

# (re)start an external agent's daemon only if it is down — idempotent; cron-driven.
# Folds in the old standalone keepalive (@reboot + every few minutes keeps it alive).
# Keep EVERY installed agent up, not just one. With no argument it sweeps them all, so a
# newly-added agent is durable the moment it is installed — no crontab edit needed.
ext_keepalive() {
  export PATH="${LAB_NODE_BIN:+$LAB_NODE_BIN:}$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"
  local agents k klog out
  if [ -n "${1:-}" ]; then agents="$1"; else agents="$(ext_agent_keys)"; fi
  [ -n "$agents" ] || return 0
  while read -r k; do
    [ -n "$k" ] || continue
    ext_has_adapter "$k" || continue          # not set up yet — nothing to keep alive
    klog="$LAB_HOME/ext/$k/keepalive.log"     # this agent's own log, never another's
    mkdir -p "$(dirname "$klog")" 2>/dev/null || true
    out="$("$SELF/lab-ext" "$k" start 2>&1)" || true
    case "$out" in
      *"already running"*) : ;;
      *) printf '%s  %s\n' "$(date '+%F %T')" "$(printf '%s' "$out" | tr '\n' ' ')" >> "$klog" 2>/dev/null || true ;;
    esac
  done <<EOF
$agents
EOF
}

sub="${1:-list}"; shift || true
case "$sub" in
  ""|list|ls)      ext_list;;
  -h|--help|help)  usage;;
  setup)           ext_setup "$@";;
  keepalive)       ext_keepalive "$@";;
  *)
    use_agent "$sub"
    act="${1:-status}"; shift || true
    case "$act" in
      start)          agent_start;;
      stop)           agent_stop;;
      restart)        agent_stop; agent_start;;
      status)         agent_status;;
      logs)           agent_logs "$@";;
      send|ask)       agent_send "$@";;
      threads)        agent_threads;;
      chat|attach)    agent_chat "$@";;
      -h|--help|help) usage;;
      *)              die "unknown action '$act' for agent '$sub' (try: status)";;
    esac;;
esac
