# $LAB_HOME/lab.env — per-install overrides, sourced automatically by the lab CLI.
# NOT committed. Copy to $LAB_HOME/lab.env and edit. Everything here is optional;
# the defaults shown are what you get if you set nothing.

# ── health check: what counts as "wrong" ─────────────────────────────────────
# A fast-moving lab and a slow one disagree about these, so none are baked in.
#LAB_STALE_WORKING_H=24    # a session marked "working" but untouched this long -> flag
#LAB_INBOX_BACKLOG_H=48    # unread mail older than this -> agent isn't picking up coordination
#LAB_TASK_STALE_D=5        # a task unclaimed / untouched this many days -> flag
#LAB_BOARD_RECENT_D=7      # window counted as "recent" announcements
#LAB_EXT_QUEUE_WARN=5      # external reviewer queue depth that means a backlog

# ── daily health check: judgement + alerting ─────────────────────────────────
#LAB_JUDGE=1                       # 0 = skip the LLM pass entirely (raw facts only, no token spend)
#LAB_JUDGE_MODEL=sonnet            # model for the judgement pass
#LAB_JUDGE_CMD="claude -p --model sonnet"   # or ANY prompt-in / text-out CLI
#LAB_ALERT_CMD=notify-send         # takes "<title>" "<body>" — swap for mail/slack/pushover.
                                   # notify-send only works on a Linux desktop; on a headless
                                   # box set this or alerts go nowhere.

# ── messaging / roster ───────────────────────────────────────────────────────
#LAB_IDLE_MIN=360          # minutes of inactivity before a session stops being a valid send target
#LAB_WATCH_INTERVAL=30     # seconds between inbox polls for `lab watch`

# ── external reviewer (lab ext) ──────────────────────────────────────────────
# Put the reviewer's work dir on SCRATCH — transcripts and logs accumulate.
#LAB_CODEX_WORK=/path/to/scratch/lab-codex
#LAB_CODEX_CD=/path/to/project      # repo root it inspects (read-only). Default: $PWD
#LAB_CODEX_MODEL=gpt-5.6-sol
#LAB_CODEX_BIN=codex                # reviewer CLI
#LAB_CODEX_REASONING=xhigh
#LAB_CODEX_SANDBOX=read-only        # leave read-only unless you really mean it
#LAB_CODEX_INTERVAL=30              # seconds between inbox polls
#LAB_CODEX_TIMEOUT=900              # per-review timeout, seconds
#LAB_NODE_BIN=$HOME/.nvm/versions/node/vXX.X.X/bin   # if the CLI is a node app under nvm

# ── wording you can own ──────────────────────────────────────────────────────
# Drop these files in to replace the built-in text (no code edits needed):
#   $LAB_HOME/templates/meeting-agenda.md   ({{id}} is substituted)
#   $LAB_HOME/templates/tuesday-delta.md
