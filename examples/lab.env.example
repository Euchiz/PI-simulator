# $LAB_HOME/lab.env — per-install overrides, sourced by the lab CLI. NOT committed.
# Copy to $LAB_HOME/lab.env and edit. Everything here is optional.

# --- external reviewer (lab ext / lab-codex) ---
# Where the reviewer keeps prompts, outputs and thread state. Put this on SCRATCH,
# not on your home filesystem — transcripts and logs accumulate.
#LAB_CODEX_WORK=/path/to/scratch/lab-codex
# Repo root the reviewer inspects (read-only). Defaults to $PWD.
#LAB_CODEX_CD=/path/to/project
#LAB_CODEX_MODEL=gpt-5.6-sol
# If the reviewer CLI is a node app installed outside the default PATH (e.g. nvm):
#LAB_NODE_BIN=$HOME/.nvm/versions/node/vXX.X.X/bin

# --- roster / messaging ---
# Minutes since a session's last activity before it stops being a valid send target.
#LAB_IDLE_MIN=360
# Seconds between inbox polls for `lab watch`.
#LAB_WATCH_INTERVAL=60
