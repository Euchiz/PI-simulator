{
  "_comment": "Claude Code SessionStart hook: read the inbox and prompt the agent to arm a live watcher. Put this in your project's .claude/settings.json. Adjust the path to your install.",
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "lab read 2>/dev/null; printf '%s\\n' '[lab] If you have NOT already armed a lab-watch Monitor in THIS session, arm one now: Monitor(command: \"lab watch\", description: \"incoming lab messages\", persistent: true). If one is already running (this also fires on resume/compact), do NOTHING.'; true" } ] }
    ]
  }
}
